@model PROGPOEP2.Models.ServiceRequest

<h2>Create Service Request</h2>

<form asp-action="Create" method="post">

    <div>
        <p>Contract</p>

        <select asp-for="ContractId" class="form-control">
            <option value="">-- Select Contract --</option>

            @if (ViewBag.Contracts != null)
            {
                foreach (var c in ViewBag.Contracts)
                {
                    <option value="@c.Id">
                        Contract @c.Id - @c.Client?.Name
                    </option>
                }
            }
        </select>
    </div>

    <div>
        <p>Description</p>
        <input asp-for="Description" class="form-control" />
    </div>

    <div>
        <p>USD Amount</p>
        <input name="usdAmount" type="number" step="0.01" class="form-control" />
    </div>

    <div>
        <button type="submit">Submit</button>
    </div>

</form>