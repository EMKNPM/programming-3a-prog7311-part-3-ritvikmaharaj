@model PROGPOEP2.Models.ServiceRequest

<h2>Create Service Request</h2>

<form asp-action="Create" method="post">

    <div>
        <p>Contract</p>
        <select asp-for="ContractId">
            <option value="">-- Select Contract --</option>

            @foreach (var c in ViewBag.Contracts)
            {
                <option value="@c.Id">
                    @c.Id - @c.Client.Name
                </option>
            }
        </select>
    </div>

    <div>
        <p>Description</p>
        <input asp-for="Description" />
    </div>

    <div>
        <p>USD Amount</p>
        <input name="usdAmount" type="number" step="0.01" />
    </div>

    <div>
        <button type="submit">Submit</button>
    </div>

</form>